{
  "name": "ds-agent",
  "version": "2.0.0",
  "description": "DS Agent — pi-coding-agent harness on top of DeepSeek (no API key required)",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test:protocol": "node scripts/test-protocol.js",
    "test:http": "node scripts/test-http.js",
    "test:bridge": "node scripts/test-llm-bridge.js",
    "test:pi": "node scripts/test-pi-integration.js",
    "test": "npm run test:protocol && npm run test:http && npm run test:bridge && npm run test:pi",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build": "electron-builder",
    "generate-icons": "ELECTRON_RUN_AS_NODE= electron scripts/icon-gen.js",
    "dist": "node scripts/build.js"
  },
  "author": "ds-enhance",
  "license": "GPL-3.0",
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0"
  },
  "build": {
    "appId": "com.ds-enhance.agent",
    "productName": "DS Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json",
      "!**/*.map"
    ],
    "asar": true,
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "asarUnpack": [
      "src/main/pty-host.js",
      "node_modules/@earendil-works/**",
      "node_modules/@xterm/**",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**",
      "node_modules/**/build/Release/**",
      "node_modules/**/prebuilds/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DS Agent"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "assets/icon.png"
    }
  }
}
